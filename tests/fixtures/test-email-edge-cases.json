{
  "_description": "Boundary and multiline email masking cases.",
  "cases": [
    {
      "id": "EDGE-01",
      "name": "Email at start of line",
      "input": "alice@example.com is the contact",
      "expect_masked": true,
      "expect_output": "[MASKED-EMAIL] is the contact"
    },
    {
      "id": "EDGE-02",
      "name": "Email at end of line",
      "input": "Reach me at alice@example.com",
      "expect_masked": true,
      "expect_output": "Reach me at [MASKED-EMAIL]"
    },
    {
      "id": "EDGE-03",
      "name": "Email inside URL query",
      "input": "https://example.com/reset?email=alice@example.com",
      "expect_masked": true,
      "expect_output": "https://example.com/reset?email=[MASKED-EMAIL]"
    },
    {
      "id": "EDGE-04",
      "name": "Multiple lines with two emails",
      "input": "line1: alice@example.com\nline2: bob@example.org",
      "expect_masked": true,
      "expect_contains": "line1: [MASKED-EMAIL]",
      "expect_also_contains": [
        "line2: [MASKED-EMAIL]"
      ]
    },
    {
      "id": "EDGE-05",
      "name": "Already masked placeholder passes through",
      "input": "email: [MASKED-EMAIL]",
      "expect_masked": false
    },
    {
      "id": "EDGE-06",
      "name": "Malformed double at sign",
      "input": "email: alice@@example.com",
      "expect_masked": false
    },
    {
      "id": "EDGE-07",
      "name": "Trailing punctuation is preserved",
      "input": "Send to alice@example.com.",
      "expect_masked": true,
      "expect_output": "Send to [MASKED-EMAIL]."
    },
    {
      "id": "EDGE-08",
      "name": "Quoted JSON email among safe fields",
      "input": "{\"owner\":\"alice@example.com\",\"status\":\"queued\"}",
      "expect_masked": true,
      "expect_output": "{\"owner\":\"[MASKED-EMAIL]\",\"status\":\"queued\"}"
    }
  ]
}