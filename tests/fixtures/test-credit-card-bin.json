{
  "_description": "Test credit card masking with BIN-prefix matching",
  "cases": [
    {
      "id": "CC-BIN-01",
      "name": "BIN 970416 exact 16 digits",
      "input": "card: 9704160123456789",
      "expect_masked": true,
      "expect_output": "card: [MASKED-CC]"
    },
    {
      "id": "CC-BIN-02",
      "name": "BIN 404169 exact 16 digits",
      "input": "card: 4041691234567890",
      "expect_masked": true,
      "expect_output": "card: [MASKED-CC]"
    },
    {
      "id": "CC-BIN-03",
      "name": "BIN 411111 exact 16 digits (Visa test)",
      "input": "number: 4111111111111111",
      "expect_masked": true,
      "expect_output": "number: [MASKED-CC]"
    },
    {
      "id": "CC-BIN-04",
      "name": "17 digits starting with BIN - should NOT match BIN pattern",
      "input": "value: 97041601234567890",
      "expect_masked_by": "generic-fallback",
      "note": "17 digits is not 16, BIN pattern should not match. Generic \\b\\d{16}\\b also wont match because it's 17."
    },
    {
      "id": "CC-BIN-05",
      "name": "18 digits starting with BIN - should NOT match 16-digit pattern",
      "input": "value: 970416012345678901",
      "expect_masked": false,
      "note": "18 digits; no 16-digit boundary match"
    },
    {
      "id": "CC-BIN-06",
      "name": "15 digits starting with BIN - should NOT match",
      "input": "value: 970416012345678",
      "expect_masked": false,
      "note": "15 digits, not 16"
    },
    {
      "id": "CC-BIN-07",
      "name": "16 digits but unknown BIN (no match)",
      "input": "card: 1234567890123456",
      "expect_masked_by": "generic-16-digit",
      "note": "Not a known BIN, but generic 16-digit pattern should catch it if enabled"
    },
    {
      "id": "CC-BIN-08",
      "name": "BIN 970416 embedded in longer number (20 digits)",
      "input": "ref: 97041601234567890123",
      "expect_masked": false,
      "note": "20 digits; word boundary \\b prevents match"
    },
    {
      "id": "CC-BIN-09",
      "name": "BIN match at end of longer string with non-digit separator",
      "input": "id:ABC-9704160123456789",
      "expect_masked": true,
      "note": "Hyphen acts as word boundary, so BIN 16 digits should match"
    },
    {
      "id": "CC-BIN-10",
      "name": "Two cards in same line",
      "input": "primary: 9704160123456789, secondary: 4041691234567890",
      "expect_masked": true,
      "expect_output": "primary: [MASKED-CC], secondary: [MASKED-CC]"
    }
  ]
}
