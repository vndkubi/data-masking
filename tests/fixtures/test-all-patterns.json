{
  "_description": "Test all sensitive data patterns: API keys, tokens, passwords, phone numbers, IDs, etc.",
  "cases": [
    {
      "id": "KEY-01",
      "name": "AWS Access Key",
      "input": "aws_key=AKIAIOSFODNN7EXAMPLE",
      "expect_masked": true,
      "expect_output": "aws_key=[MASKED-AWS-KEY]"
    },
    {
      "id": "KEY-02",
      "name": "API Key (sk- prefix)",
      "input": "key: sk-abc12345678901234567890",
      "expect_masked": true,
      "expect_contains": "[MASKED-KEY]"
    },
    {
      "id": "KEY-03",
      "name": "API Key (token_ prefix)",
      "input": "auth: token_xyzABCDEF12345678901234",
      "expect_masked": true,
      "expect_contains": "[MASKED-KEY]"
    },
    {
      "id": "TOKEN-01",
      "name": "Bearer token",
      "input": "Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVC",
      "expect_masked": true,
      "expect_contains": "[MASKED-TOKEN]"
    },
    {
      "id": "TOKEN-02",
      "name": "Bearer with short value (9 chars) - should NOT match",
      "input": "Authorization: Bearer abc123def",
      "expect_masked": false,
      "note": "Token is < 10 chars"
    },
    {
      "id": "CONN-01",
      "name": "MongoDB connection string",
      "input": "uri: mongodb://admin:p4ssw0rd@cluster0.example.net:27017/mydb",
      "expect_masked": true,
      "expect_contains": "[MASKED-CONN]"
    },
    {
      "id": "CONN-02",
      "name": "PostgreSQL connection string",
      "input": "db=postgresql://user:secret@db.host.com:5432/production",
      "expect_masked": true,
      "expect_contains": "[MASKED-CONN]"
    },
    {
      "id": "PASS-01",
      "name": "Password key=value",
      "input": "password=MySuperSecretP@ss!",
      "expect_masked": true,
      "expect_contains": "[MASKED-PASS]"
    },
    {
      "id": "PASS-02",
      "name": "Password with colon separator",
      "input": "secret: my-api-secret-value",
      "expect_masked": true,
      "expect_contains": "[MASKED-PASS]"
    },
    {
      "id": "PHONE-01",
      "name": "Vietnamese phone +84",
      "input": "phone: +84912345678",
      "expect_masked": true,
      "expect_output": "phone: [MASKED-PHONE]"
    },
    {
      "id": "PHONE-02",
      "name": "Vietnamese phone 0-prefix",
      "input": "sdt: 0912345678",
      "expect_masked": true,
      "expect_output": "sdt: [MASKED-PHONE]"
    },
    {
      "id": "PHONE-03",
      "name": "Phone with only 8 digits after 0 - should NOT match",
      "input": "ref: 012345678",
      "expect_masked_by": "9-digit-CMND",
      "note": "9 total digits matches CMND pattern instead"
    },
    {
      "id": "ID-01",
      "name": "CCCD Vietnam 12 digits",
      "input": "cccd: 012345678901",
      "expect_masked": true,
      "expect_contains": "[MASKED-CCCD]"
    },
    {
      "id": "ID-02",
      "name": "CMND Vietnam 9 digits",
      "input": "cmnd: 012345678",
      "expect_masked": true,
      "expect_contains": "[MASKED-ID]"
    },
    {
      "id": "CVV-01",
      "name": "CVV in JSON",
      "input": "{\"cvv\": \"123\"}",
      "expect_masked": true,
      "expect_contains": "[MASKED-CVV]"
    },
    {
      "id": "BANK-01",
      "name": "Bank account 13 digits",
      "input": "account: 1234567890123",
      "expect_masked": true,
      "expect_contains": "[MASKED-BANK]"
    },
    {
      "id": "PK-01",
      "name": "Private key block",
      "input": "-----BEGIN RSA PRIVATE KEY-----\nMIIEpAIBAAKCAQEA0Z3VS5JJcds3xfn/ygWyF\n-----END RSA PRIVATE KEY-----",
      "expect_masked": true,
      "expect_contains": "[MASKED-PRIVATE-KEY]"
    },
    {
      "id": "SAFE-01",
      "name": "Normal text no sensitive data",
      "input": "Hello, this is a normal message with no secrets.",
      "expect_masked": false
    },
    {
      "id": "SAFE-02",
      "name": "Short number (5 digits) - not sensitive",
      "input": "order: 12345",
      "expect_masked": false
    }
  ]
}
