{
  "_description": "Test formatted credit cards (spaced/dashed)",
  "cases": [
    {
      "id": "CC-FMT-01",
      "name": "Formatted with spaces (Visa)",
      "input": "card: 4111 1111 1111 1111",
      "expect_masked": true,
      "expect_output": "card: [MASKED-CC]"
    },
    {
      "id": "CC-FMT-02",
      "name": "Formatted with dashes",
      "input": "card: 4111-1111-1111-1111",
      "expect_masked": true,
      "expect_output": "card: [MASKED-CC]"
    },
    {
      "id": "CC-FMT-03",
      "name": "Formatted with BIN 9704 16xx",
      "input": "card: 9704 1601 2345 6789",
      "expect_masked": true,
      "expect_output": "card: [MASKED-CC]"
    },
    {
      "id": "CC-FMT-04",
      "name": "Mixed format (space then dash) should still match generic",
      "input": "card: 4111 1111-1111 1111",
      "expect_masked": true,
      "expect_output": "card: [MASKED-CC]"
    },
    {
      "id": "CC-FMT-05",
      "name": "5 groups - partial match expected",
      "input": "ref: 4111 1111 1111 1111 0000",
      "expect_masked": true,
      "note": "First 4 groups match the 4x4 pattern; trailing 0000 remains unmasked",
      "expect_contains": "[MASKED-CC]"
    }
  ]
}
