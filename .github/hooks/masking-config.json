{
  "patterns": [
    {
      "name": "Private Key/Certificate",
      "regex": "-----BEGIN [A-Z ]+KEY-----[\\s\\S]*?-----END [A-Z ]+KEY-----",
      "regexBash": "-----BEGIN [A-Z ]+KEY-----[^-]*-----END [A-Z ]+KEY-----",
      "replacement": "[MASKED-PRIVATE-KEY]"
    },
    {
      "name": "Credit Card (16 digits)",
      "regex": "\\b\\d{16}\\b",
      "replacement": "[MASKED-CC]"
    },
    {
      "name": "Credit Card (formatted)",
      "regex": "\\b\\d{4}[- ]\\d{4}[- ]\\d{4}[- ]\\d{4}\\b",
      "replacement": "[MASKED-CC]"
    },
    {
      "name": "AWS Access Key",
      "regex": "AKIA[0-9A-Z]{16}",
      "replacement": "[MASKED-AWS-KEY]"
    },
    {
      "name": "API Key",
      "regex": "(?i)(sk|pk|api|token|key)[-_][a-zA-Z0-9]{20,}",
      "replacement": "\\1-[MASKED-KEY]"
    },
    {
      "name": "Bearer Token",
      "regex": "(?i)(Bearer\\s+)[a-zA-Z0-9_.~+/=-]{10,}",
      "replacement": "\\1[MASKED-TOKEN]"
    },
    {
      "name": "Connection String",
      "regex": "(?i)(mongodb|postgresql|mysql|redis)://[^@]+@[^\\s\"]+",
      "replacement": "\\1://[MASKED-CONN]"
    },
    {
      "name": "Password in key=value",
      "regex": "(?i)(password|passwd|pwd|secret|pass)\\s*[=:]\\s*[^\\s\"}{,]+",
      "replacement": "\\1=[MASKED-PASS]"
    },
    {
      "name": "CCCD Vietnam (12 digits)",
      "regex": "\\b\\d{12}\\b",
      "replacement": "[MASKED-CCCD]"
    },
    {
      "name": "Bank Account (10-14 digits)",
      "regex": "\\b\\d{10,14}\\b",
      "replacement": "[MASKED-BANK-ACC]"
    },
    {
      "name": "Vietnamese Phone Number",
      "regex": "(\\+84|0)\\d{9}\\b",
      "replacement": "[MASKED-PHONE]"
    },
    {
      "name": "CMND Vietnam (9 digits)",
      "regex": "\\b\\d{9}\\b",
      "replacement": "[MASKED-ID]"
    },
    {
      "name": "CVV/CVC",
      "regex": "(?i)(cvv|cvc|cvc2|cvv2)\"\\s*:\\s*\"\\d{3,4}\"",
      "replacement": "\\1\": \"[MASKED-CVV]\""
    }
  ],
  "customPatterns": [
    {
      "name": "[MASKED-MY-SPECIAL-TOKEN]",
      "regex": "(?i)MySpecialToken_[a-zA-Z0-9]{15,}"
    }
  ],
  "externalToolsRegex": "^(search_web|fetch_webpage|mcp_.*|github_repo|external_api_call)$"
}
