{
  "hooks": {
    "PreCompact": [
      {
        "type": "command",
        "command": "bash .github/hooks/scripts/05-pre-compact.sh",
        "linux": "bash .github/hooks/scripts/05-pre-compact.sh",
        "osx": "bash .github/hooks/scripts/05-pre-compact.sh",
        "windows": "powershell -ExecutionPolicy Bypass -File .github/hooks/scripts/05-pre-compact.ps1",
        "timeout": 15
      }
    ]
  }
}