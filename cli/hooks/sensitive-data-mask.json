{
  "version": 1,
  "hooks": {
    "SessionStart": [
      {
        "type": "command",
        "bash": "pwsh -NoLogo -NoProfile -File \"$HOME/.copilot/hooks/scripts/mask-sensitive-data.ps1\"",
        "powershell": "& \"$HOME/.copilot/hooks/scripts/mask-sensitive-data.ps1\"",
        "timeoutSec": 15
      }
    ],
    "PreToolUse": [
      {
        "type": "command",
        "bash": "pwsh -NoLogo -NoProfile -File \"$HOME/.copilot/hooks/scripts/mask-sensitive-data.ps1\"",
        "powershell": "& \"$HOME/.copilot/hooks/scripts/mask-sensitive-data.ps1\"",
        "timeoutSec": 15
      }
    ],
    "PreCompact": [
      {
        "type": "command",
        "bash": "pwsh -NoLogo -NoProfile -File \"$HOME/.copilot/hooks/scripts/mask-sensitive-data.ps1\"",
        "powershell": "& \"$HOME/.copilot/hooks/scripts/mask-sensitive-data.ps1\"",
        "timeoutSec": 15
      }
    ],
    "SubagentStart": [
      {
        "type": "command",
        "bash": "pwsh -NoLogo -NoProfile -File \"$HOME/.copilot/hooks/scripts/mask-sensitive-data.ps1\"",
        "powershell": "& \"$HOME/.copilot/hooks/scripts/mask-sensitive-data.ps1\"",
        "timeoutSec": 15
      }
    ]
  }
}