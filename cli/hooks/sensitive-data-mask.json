{
  "version": 1,
  "hooks": {
    "SessionStart": [
      {
        "type": "command",
        "bash": "$HOME/.copilot/hooks/scripts/mask-sensitive-data.sh",
        "powershell": "& \"$HOME/.copilot/hooks/scripts/mask-sensitive-data.ps1\"",
        "timeoutSec": 15
      }
    ],
    "UserPromptSubmit": [
      {
        "type": "command",
        "bash": "$HOME/.copilot/hooks/scripts/mask-sensitive-data.sh",
        "powershell": "& \"$HOME/.copilot/hooks/scripts/mask-sensitive-data.ps1\"",
        "timeoutSec": 15
      }
    ],
    "PreToolUse": [
      {
        "type": "command",
        "bash": "$HOME/.copilot/hooks/scripts/mask-sensitive-data.sh",
        "powershell": "& \"$HOME/.copilot/hooks/scripts/mask-sensitive-data.ps1\"",
        "timeoutSec": 15
      }
    ],
    "PreCompact": [
      {
        "type": "command",
        "bash": "$HOME/.copilot/hooks/scripts/mask-sensitive-data.sh",
        "powershell": "& \"$HOME/.copilot/hooks/scripts/mask-sensitive-data.ps1\"",
        "timeoutSec": 15
      }
    ],
    "PostToolUse": [
      {
        "type": "command",
        "bash": "$HOME/.copilot/hooks/scripts/mask-sensitive-data.sh",
        "powershell": "& \"$HOME/.copilot/hooks/scripts/mask-sensitive-data.ps1\"",
        "timeoutSec": 15
      }
    ]
  }
}
