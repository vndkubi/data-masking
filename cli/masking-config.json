{
  "externalToolsRegex": "^(search_web|fetch_webpage|mcp_.*|github_repo)$",
  "sensitiveFilenameRegex": "(^|[\\/])\\d{9,16}(\\.[^\\/]+)?$",
  "patterns": [
    {
      "name": "Private Key",
      "enabled": true,
      "regex": "-----BEGIN [A-Z ]+KEY-----[\\s\\S]*?-----END [A-Z ]+KEY-----",
      "replacement": "[MASKED-PRIVATE-KEY]"
    },
    {
      "name": "Credit Card",
      "enabled": true,
      "regex": "\\b(?:\\d{4}[- ]?){3}\\d{4}\\b",
      "replacement": "[MASKED-CC]"
    },
    {
      "name": "Bearer Token",
      "enabled": true,
      "regex": "(?i)Bearer\\s+[A-Za-z0-9._\\-]{10,}",
      "replacement": "Bearer [MASKED-TOKEN]"
    },
    {
      "name": "API Key",
      "enabled": true,
      "regex": "(?i)\\b(?:sk|pk|rk|token|api[_-]?key)[-_=: ]*[A-Za-z0-9._\\-]{12,}\\b",
      "replacement": "[MASKED-KEY]"
    },
    {
      "name": "Password Assignment",
      "enabled": true,
      "regex": "(?i)\\b(password|passwd|secret|pwd)\\b\\s*[:=]\\s*[^,\\s\"'}]{4,}",
      "replacement": "$1=[MASKED-PASS]"
    }
  ]
}